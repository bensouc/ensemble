<!doctype html>
<html>
	<head>
		<meta charset='utf-8' />
		<!-- Bootstrap CSS (local) -->
		<style>
			<%= raw(
			if Rails.application.assets
				Rails.application.assets["bootstrap-pdf.min.css"]&.to_s
			else
				File.read(Rails.root.join("public", "assets", Rails.application.assets_manifest.assets["bootstrap-pdf.min.css"]))
			end
		) %>
		</style>
		<title><%= @title%></title>
		<style>
			<%= raw(
			if Rails.application.assets
				# Development: use Sprockets
				Rails.application.assets["pdf.css"]&.to_s
			else
				# Production: read precompiled asset from public/assets/
				File.read(Rails.root.join("public", "assets", Rails.application.assets_manifest.assets["pdf.css"]))
			end
		) %>
		</style>
		<meta http-equiv="content-type" content="text/html; charset=utf-8" />
	</head>
	<body>
		<%= yield %>
	</body>
</html>
